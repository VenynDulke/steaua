    <style>
        /* Estilos generales */
        body {
            margin: 0;
            padding: 0;
            background-color: #000001; /* Fondo Negro */
            background-size: cover;
            font-family: 'Arial', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            /* Cursor personalizado */
            cursor: url('https://xatimg.com/image/qcge7iRhO3IU.png'), auto;
        }

        /* Estilos para el tГ­tulo principal */
        h1.main-title {
            margin: 0;
            color: #b1b1b1;
            text-shadow: 0 0 10px rgba(177, 177, 177, 0.7);
            font-size: 3em;
            font-weight: bold;
            background: linear-gradient(#383838, #b1b1b1, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: textGlow 1.5s ease-in-out infinite;
        }

        @keyframes textGlow {
            0% { text-shadow: 0 0 5px rgba(177, 177, 177, 0.5); }
            50% { text-shadow: 0 0 15px rgba(177, 177, 177, 1); }
            100% { text-shadow: 0 0 5px rgba(177, 177, 177, 0.5); }
        }

        /* Contenedor principal del perfil */
        .profile-container {
            width: 95%;
            max-width: 900px;
            margin: 50px auto;
            padding: 20px;
            background-color: rgba(25, 25, 25, 0.8);
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(168, 168, 168, 0.7);
            position: relative;
            display: flex;
            flex-direction: column;
            min-height: calc(100vh - 100px);
            transition: all 0.5s ease;
        }

        .profile-cover {
            width: 100%;
            height: 150px;
            background: linear-gradient(to bottom, #1a1a1a, #000001);
            background-size: cover;
            position: relative;
            border-bottom: 5px solid #141414;
            border-radius: 5px 5px 0 0;
        }

        .avatar-container {
            position: absolute;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            width: 150px;
            height: 150px;
            border-radius: 5%;
            overflow: hidden;
            border: 5px solid #000001;
            box-shadow: 0 0 15px rgba(168, 168, 168, 0.7);
            z-index: 10;
        }

        .avatar {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-details {
            text-align: center;
            margin-top: 100px;
        }

        .profile-details p {
            margin: 10px 0;
            font-size: 1.1rem;
            color: #D3D3D3;
            font-style: italic;
        }

        .profile-buttons {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .btn-style {
            display: inline-block;
            padding: 12px 25px;
            text-decoration: none;
            color: #fff;
            background-color: #606060;
            border: none;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: bold;
            cursor: url('https://xatimg.com/image/qcge7iRhO3IU.png'), pointer;
            transition: background-color 0.3s, transform 0.3s;
        }

        .btn-style:hover {
            background-color: #000001;
            transform: scale(1.05);
        }

        /* Tarjetas de informaciГіn */
        .info-cards {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            margin-top: 30px;
            gap: 20px;
        }

        .info-card {
            background-color: rgba(96, 96, 96, 0.9);
            border: 1px solid #000001;
            border-radius: 8px;
            padding: 20px;
            flex: 1 1 30%;
            box-shadow: 0 4px 8px rgba(168, 168, 168, 0.7);
            transition: transform 0.3s, box-shadow 0.3s;
            margin-bottom: 20px;
            min-width: 250px;
        }

        .info-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 6px 12px rgba(229, 229, 229, 1);
        }

        .info-card h3 {
            margin-top: 0;
            color: #191919;
            font-size: 1.5rem;
        }

        .info-card p {
            margin: 10px 0;
            color: #ffffff;
        }

        .spotify-container {
            margin-top: 20px;
            width: 100%;
        }

        .footer-text {
            text-align: center;
            margin-top: auto;
            padding-top: 20px;
            color: #ffffff;
            font-size: 1rem;
            font-weight: bold;
        }

        /* VISTAS */
        #view-profile {
            display: block;
            animation: fadeIn 0.5s;
        }
        
        #view-gifs {
            display: none;
            animation: fadeIn 0.5s;
            margin-top: 20px;
            width: 100%;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ESTILOS PARA LA SECCIГ“N DE GIFS */
        .gifs-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 1px solid #525252;
            padding-bottom: 10px;
        }

        .canvas-container {
            width: 100%;
            display: flex;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 20px;
            background: #000;
            border-radius: 10px;
            border: 2px solid #525252;
        }

        .marquee-banner {
            margin: 20px auto;
            padding: 5px;
            width: 95%;
            height: 35px;
            text-align: center;
            border-radius: 7px;
            border: 2px solid #525252;
            box-shadow: rgba(82, 82, 82, 0.1) 0px 8px 24px, rgba(82, 82, 82, 0.1) 0px 16px 56px;
