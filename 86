            color: #fff;
            text-shadow: 0 0 5px #f00;
            font-size: 20px;
            display: flex;
            align-items: center;
        }

        .gif-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
            gap: 15px;
            justify-items: center;
            padding: 10px 0;
        }

        .gif-item {
            width: 110px;
            height: 120px;
            background-color: #1b1b1b;
            border: 1px solid rgb(82, 82, 82);
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            transition: transform 0.2s;
        }

        .gif-item:hover {
            transform: scale(1.1);
            border-color: #fff;
        }

        .gif-item span {
            color: #ffffff;
            font-weight: bold;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .gif-item img {
            max-width: 80px;
            max-height: 80px;
            object-fit: contain;
        }

